<![CDATA[<p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><font face="Arial, sans-serif">Hello<o:p></o:p></font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><font face="Arial, sans-serif">&nbsp;</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><span lang="FR"><font face="Arial, sans-serif">Your approval is required to Terminate Agreement&nbsp;{!Convention__c.Name} with the following details :<o:p></o:p></font></span></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><span lang="FR"><font face="Arial, sans-serif">&nbsp;</font></span></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><span lang="FR" style="caret-color: rgb(0, 0, 0);"><font face="Arial, sans-serif">Agreement Type :&nbsp;</font></span><span style="background-color: rgb(255, 255, 255); font-family: Arial, sans-serif; font-size: 12pt;">{!Convention__c.Code_Type__c}</span></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><span lang="FR" style="caret-color: rgb(0, 0, 0);"><font face="Arial, sans-serif">Rebates Grid :&nbsp;<o:p></o:p></font></span><font face="Arial, sans-serif">{!Convention__c.Grid__c}</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><font face="Arial, sans-serif" style="caret-color: rgb(0, 0, 0);">Agreement Region:<span class="Apple-converted-space">&nbsp;</span><o:p></o:p></font><font face="Arial, sans-serif">{!Convention__c.Business_Region__c}</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><font face="Arial, sans-serif" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;">Status:&nbsp;</font><font face="Arial, sans-serif">{!Convention__c.Status__c}</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><font style="font-size: 12pt; caret-color: rgb(0, 0, 0);">Cancellation Date:&nbsp;<font face="Arial, sans-serif"><o:p></o:p></font></font><font face="Arial, sans-serif">{!Convention__c.Cancellation_Date__c}</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><font face="Arial, sans-serif"><br></font></p><p class="MsoNormal" style="margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><font face="Arial, sans-serif" style="">Comment For Approval : {!Convention__c.CommentForApproval__c}</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><font face="Arial, sans-serif"><br></font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; background-color: rgb(255, 255, 255); text-size-adjust: auto;"><font face="Arial, sans-serif">Latest Approval Comment :</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; background-color: rgb(255, 255, 255); text-size-adjust: auto;"><font face="Arial, sans-serif">{!ApprovalRequest.Comments}</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><span style="font-family: Arial, sans-serif; font-size: 12pt; caret-color: rgb(0, 0, 0);">&nbsp;</span></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><span lang="FR" style="font-size: 12pt; caret-color: rgb(0, 0, 0);"><font face="Arial, sans-serif">Please view and validate the Agreement Termination information by clicking here </font></span><font face="Arial, sans-serif">{!Convention__c.Link}</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><span lang="FR"><font face="Arial, sans-serif">&nbsp;</font></span></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><span lang="FR"><font face="Arial, sans-serif">&nbsp;</font></span></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><span style="font-family: Arial, sans-serif;">This is an automated email, please do no reply to this email.</span></p>]]></td>
