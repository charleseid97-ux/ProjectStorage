<td tEditID="c1r1" style=" background-color:#FFFFFF; bEditID:r3st1; color:#000000; bLabel:main; font-size:12pt; font-family:arial;" aEditID="c1r1" locked="0" >
<![CDATA[<div style=""><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><font face="Arial, sans-serif" style="">Hello<o:p></o:p></font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><font face="Arial, sans-serif">&nbsp;</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><span lang="FR" style=""><font face="Arial, sans-serif">Your approval is required for a Grid Amendment on Agreement&nbsp;{!Convention__c.Name}. The agreement was submitted with the following details :<o:p></o:p></font></span></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><span lang="FR" style=""><font face="Arial, sans-serif">&nbsp;</font></span></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><span lang="FR" style="font-size: 12pt; caret-color: rgb(0, 0, 0);"><font face="Arial, sans-serif">Current Grid:&nbsp;<o:p></o:p></font></span><font face="Arial, sans-serif" style="font-size: 12pt;">{!Convention__c.Grid__c}</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><font face="Arial, sans-serif" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; caret-color: rgb(0, 0, 0);">Proposed Grid:<span class="Apple-converted-space">&nbsp;</span></font><font face="Arial, sans-serif">{!Convention__c.Grid_Request__c}</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><font face="Arial, sans-serif" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; caret-color: rgb(0, 0, 0);">Grid Start Date:&nbsp;</font><font face="arial">{!Convention__c.Grid_Request_Start_Date__c}</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><font face="arial"><br></font></p><p class="MsoNormal" style="margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><font face="arial" style="">Comment For Approval: {!Convention__c.CommentForApproval__c}</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><font face="Arial, sans-serif"><br></font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; background-color: rgb(255, 255, 255); text-size-adjust: auto;"><font face="Arial, sans-serif">Latest Approval Comment:</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><span style="font-family: Arial, sans-serif; background-color: rgb(255, 255, 255); font-size: 12pt;">{!ApprovalRequest.Comments}</span></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><font face="Arial, sans-serif">&nbsp;</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; text-size-adjust: auto;"><span lang="FR" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; caret-color: rgb(0, 0, 0);"><font face="Arial, sans-serif">Please view and validate the Agreement information by clicking here -&nbsp;</font></span><font face="Arial, sans-serif">{!Convention__c.Link}</font></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><span lang="FR" style=""><font face="Arial, sans-serif">&nbsp;</font></span></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><span lang="FR" style=""><font face="Arial, sans-serif">&nbsp;</font></span></p><p class="MsoNormal" style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt; margin: 0cm 0cm 0.0001pt; caret-color: rgb(0, 0, 0); text-size-adjust: auto;"><span lang="FR" style=""><font face="Arial, sans-serif">This is an automated email, please do no reply to this email.</font></span></p></div><div style="color: rgb(0, 0, 0); font-family: arial; font-size: 12pt;"><br></div>]]></td>
