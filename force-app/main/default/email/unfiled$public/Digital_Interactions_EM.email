<![CDATA[<table border="0" cellpadding="5" width="600" cellspacing="5" height="400"><tbody><tr valign="top" height="50"><td teditid="c1r1" aeditid="c1r1" locked="0" style="background-color: rgb(255, 255, 255); font-size: 12pt;">Dear&nbsp;{!Contact.OwnerFirstName},</td></tr><tr valign="top" height="300"><td teditid="c1r2" aeditid="c1r2" locked="0" style="background-color: rgb(255, 255, 255);"><font face="arial" style="font-size: 12pt;">We have noticed that your Contact,&nbsp;{!Contact.FirstName}&nbsp;{!Contact.LastName}, from&nbsp;{!Account.Name}, has engaged on Carmignac's website, browsing Emerging Markets related content.</font><div style="font-size: 12pt;"><br></div><div style=""><b>Business card title</b>: {!Contact.Business_Card_Title__c}</div><div style="font-size: 12pt;"><span style="font-size: medium;"><b>Persona</b>: {!Contact.Persona__c}</span></div><div style="font-size: 12pt;"><font face="arial"><b>Email</b>: <a href="mailto:">{!Contact.Email}</a></font></div><div style="font-size: 12pt;"><font face="arial"><b>Direct line</b>: {!Contact.Phone}<br></font><div><br></div><div><font face="arial"><br></font></div><div style="font-size: 12pt;">This information may be relevant for you.&nbsp;</div><div style="font-size: 12pt;">Please feel free to get in touch with him/her.</div><div style="font-size: 12pt;"><br></div><div style="font-size: 12pt;">Should you need additional information, we remain at your disposal.</div><div style="font-size: 12pt;"><br></div><div style="font-size: 12pt;">Best regards,&nbsp;</div><div style="font-size: 12pt;"><br></div><div style="font-size: 12pt;"><b>PRM/CRM Team</b></div></div></td></tr></tbody></table>]]></td>
</tr>
