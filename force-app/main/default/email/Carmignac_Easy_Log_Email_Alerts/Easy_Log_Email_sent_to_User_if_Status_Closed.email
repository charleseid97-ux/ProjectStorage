<td tEditID="c1r1" style=" background-color:#FFFFFF; bEditID:r3st1; color:#000000; bLabel:main; font-size:12pt; font-family:arial;" aEditID="c1r1" locked="0" >
<![CDATA[<font size="2" style="color: rgb(0, 0, 0); font-family: arial;">Hello&nbsp;<b style="font-family: Arial, sans-serif;">{!Bug_Log__c.Owner__c}</b><b style="font-family: Arial, sans-serif;">&nbsp;!&nbsp;</b></font><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font size="2">Please noticed that your<b>&nbsp;</b></font><font size="2"><b>{!Bug_Log__c.Name}</b>&nbsp;is now&nbsp;</font><font face="Arial, sans-serif" size="2" color="#009900"><b>{!Bug_Log__c.Status__c}</b></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font size="2"><br></font></div><div style=""><div style="color: rgb(0, 0, 0); font-family: &quot;Times New Roman&quot;;"><font size="2"><font face="arial" style="font-family: arial;">Follow the link :&nbsp;</font></font><font size="2"><font face="arial" style="font-family: arial;">&nbsp;</font></font><font face="arial" size="2" style="font-family: arial;">https://carmignac-crm.lightning.force.com/</font><font face="arial" size="2" style="font-family: arial;">lightning/r/Bug_Log__c/{!Bug_Log__c.Id}/view</font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="arial" size="2"><br></font></div></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2">Please find Administrator comments :&nbsp;</font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2">{!Bug_Log__c.AdministratorComment__c}</font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2">Result :&nbsp;</font><font face="Arial, sans-serif" size="2"><b>{!Bug_Log__c.RetestResult__c}</b></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font size="2">You case has been closed the&nbsp;</font><font face="Arial, sans-serif" size="2"><b>{!Bug_Log__c.CloseDate__c}</b></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2">Please check on your side that everything is good !&nbsp;</font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial; text-align: right;"><font face="Arial, sans-serif" size="2">Thank you for contacting Easy Log Team !</font></div><div style="font-size: 12pt; color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2"><br></font></div>]]></td>
</tr>
