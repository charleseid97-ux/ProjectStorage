<tr valign="top" height="400" >
<td tEditID="c1r1" style=" background-color:#FFFFFF; bEditID:r3st1; color:#000000; bLabel:main; font-size:12pt; font-family:arial;" aEditID="c1r1" locked="0" >
<![CDATA[<font size="2" style="color: rgb(0, 0, 0); font-family: arial;">Hello&nbsp;<font face="arial" style="">{!Bug_Log__c.AssignedTo__c}</font><b style="font-family: Arial, sans-serif;">&nbsp;!&nbsp;</b></font><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2">Please noticed that<b>&nbsp;</b></font><font face="Arial, sans-serif" size="2"><b>{!Bug_Log__c.Name}</b>&nbsp;has been assigned to you !&nbsp;</font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font size="2"><font face="Arial, sans-serif">Go on Easy Log page to check&nbsp;</font><span style="font-family: Arial, sans-serif;"><b>{!Bug_Log__c.Owner__c}</b>&nbsp;'s&nbsp;</span><span style="font-family: Arial, sans-serif;">request and provide a quick solution !</span></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font size="2"><span style="font-family: Arial, sans-serif;"><br></span></font></div><div style=""><div style="color: rgb(0, 0, 0); font-family: &quot;Times New Roman&quot;;"><font size="2"><font face="arial" style="font-family: arial;">Follow the link :&nbsp;</font></font><font size="2"><font face="arial" style="font-family: arial;">&nbsp;</font></font><font face="arial" size="2" style="font-family: arial;">https://carmignac-crm.lightning.force.com/</font><font face="arial" size="2" style="font-family: arial;">lightning/r/Bug_Log__c/{!Bug_Log__c.Id}/view</font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="arial" size="2"><br></font></div></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font size="2"><span style="font-family: Arial, sans-serif;">For information,&nbsp;</span><font face="Arial, sans-serif">&nbsp;</font><font face="Arial, sans-serif">{!Bug_Log__c.Name} concerns&nbsp;</font><font face="Arial, sans-serif"><b>{!Bug_Log__c.App__c}</b></font></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font size="2"><font face="Arial, sans-serif"><br></font></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font size="2"><font face="Arial, sans-serif">According to&nbsp;</font><span style="font-family: Arial, sans-serif;">{!Bug_Log__c.Owner__c}, it is&nbsp;</span><font face="Arial, sans-serif">{!Bug_Log__c.PrioritySeverity__c} and wish to be resolved<b>&nbsp;{!Bug_Log__c.Expected_Date__c}</b>.&nbsp;</font></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial;"><font face="Arial, sans-serif" size="2"><br></font></div><div style="color: rgb(0, 0, 0); font-family: arial; text-align: right;"><font size="2" style=""><font face="Arial, sans-serif" style="">Good Luck&nbsp;</font>{!Bug_Log__c.AssignedTo__c} !&nbsp;</font></div>]]></td>
</tr>
</table>