<aura:component implements= "force:hasRecordId">
    
	<aura:attribute name="product" type="Product__c"/>
	
	<aura:attribute name="index" type="Integer"/>
    <aura:attribute name="abbreviation" type="String"/>
    <aura:attribute name="assetClassName" type="String" default=""/>
    
    <aura:registerEvent name="navigateToSObject" type="force:navigateToSObject"/>
    <aura:registerEvent name="selectSObject" type="ltng:selectSObject"/>
    
    
    <aura:registerEvent name="GetProductId" type="c:ProductGetProdIdEvent" />
    
    
	<aura:handler name="init" value="{!this}" action="{!c.doInit}" />
    
    <li aura:id="tile" class="slds-p-horizontal--small slds-size--1-of-1 slds-medium-size--1-of-3" data-id="{#v.index}">
        <a onclick="{!c.productSelected}" class="slds-app-launcher__tile slds-text-link--reset slds-truncate">
            <div class="slds-app-launcher__tile-figure">
                <span class="{# 'slds-avatar slds-avatar--large slds-align--absolute-center '  + (v.product.RecordType.DeveloperName == 'Fund' ? 'Fund' : v.product.Asset_Class__r.Name)}">{!v.abbreviation}</span>
            </div>
            <div class="slds-app-launcher__tile-body">        
                <span class="slds-text-link">{#v.product.Name}</span>
               	<p>{#(v.product.RecordType.DeveloperName == 'Asset_Class' ? v.product.Name : v.product.Asset_Class__r.Name)}</p>
               	<p class="slds-text-body_italics">{#v.product.RecordType.Name}</p>                      
            </div>
        </a>
	</li>
	
</aura:component>