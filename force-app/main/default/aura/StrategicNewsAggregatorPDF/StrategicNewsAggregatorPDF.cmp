<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId,forceCommunity:availableForAllPageTypes,force:lightningQuickAction" 
                controller="StrategicNewsPDFController" access="global" >
    
    <aura:attribute name="fileName" type="String" default="StrategicNewsAggregator.pdf"/>
    
    <aura:registerEvent name="closeDownloadOverlay" type="c:DecisionMakerPDFCloseDownloadEvent"/>
    
    <a aura:id="theDlTag" class="slds-hide" download="{!v.fileName}">Hidden</a>
    
    <aura:method name="downloadPDF" action="{!c.doDownloadPDF}">
        <aura:attribute name="lSN" type="List"/>
        <aura:attribute name="rId" type="String" />
    </aura:method>

</aura:component>