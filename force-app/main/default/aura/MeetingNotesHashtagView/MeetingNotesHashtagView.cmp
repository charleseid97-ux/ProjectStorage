<aura:component controller="MeetingNotesHashtagViewController" implements="flexipage:availableForRecordHome,force:hasRecordId" access="global">
	<aura:attribute name="htmlData" type="String" default=""/>
    <aura:handler name="init" value="{!this}" action="{!c.init}"/>

    <lightning:card title="Notes">
        <div aura:id="textRoot" class="slds-rich-text-editor slds-grid slds-grid_vertical slds-nowrap">
            <div class="slds-rich-text-editor__textarea slds-grid ql-container">
                <div aura:id="textWrapper" class="ql-editor slds-rich-text-area__content slds-text-color_weak slds-grow">
                    <aura:unescapedHtml value="{!v.htmlData}"/>
                </div>
            </div>
        </div>
    </lightning:card>
</aura:component>