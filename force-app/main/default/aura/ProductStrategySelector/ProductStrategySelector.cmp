<aura:component implements="flexipage:availableForAllPageTypes" 
                controller="ProductSelectionCtrl" access="global">

  	<aura:registerEvent name="onchange" type="c:ProductValueChange"/>
  	
    <aura:handler event="c:ProductSelectorStrategyFilterEvent" action="{!c.sChangeHandler}"/> 
	
    <ltng:require scripts="{!$Resource.DataCache}" afterScriptsLoaded="{!c.afterScriptsLoaded}"/>
    
    <aura:attribute name="strategies" type="Product__c[]" />
    <aura:attribute name="selectedValue" type="String"/>
    
	<div>
        <lightning:layout verticalAlign="center" class="bar">
            <lightning:layoutItem flexibility="grow">
                <lightning:select aura:id="strategySelect" label="Strategy" value="{!v.selectedValue}" onchange="{!c.strategyChangeHandler}">
                    <aura:iteration items="{!v.strategies}" var="strategy">
                        <option text="{#strategy.Name}" value="{#strategy.Id}"  selected="{!strategy.IsSelectedFilter__c}"/>
                    </aura:iteration>
                </lightning:select>
            </lightning:layoutItem>
            <lightning:layoutItem >
                <lightning:buttonIcon iconName="utility:close" variant="bare" onclick="{!c.clearHandler}"/>
           </lightning:layoutItem>
       </lightning:layout>
    </div>
</aura:component>