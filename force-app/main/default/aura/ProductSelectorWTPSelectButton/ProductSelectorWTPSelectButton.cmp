<aura:component implements="force:appHostable,flexipage:availableForAllPageTypes,force:hasRecordId" access="global">
        
    <aura:attribute name="currentWTPId" type="String" default="Case"/>
    <aura:attribute name="recordId" type="String" />
    <aura:attribute name="sObjectName" type="String" default="Case"/>

    <lightning:card variant="Narrow" class="lightningCardOverflow" >
        <div class="slds-text-align_left" >
            <div style="padding-left:10px;">
                <div>Click here to <lightning:button label="Select Products" variant="success" onclick="{!c.launchProductSelector}" /></div>
            </div>
        </div>
    </lightning:card>
</aura:component>