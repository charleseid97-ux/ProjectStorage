<aura:component controller="AccountHierarchyCtrl" implements="force:appHostable,flexipage:availableForAllPageTypes,flexipage:availableForRecordHome,force:hasRecordId"> 
    <aura:attribute name="GAMId" type="string" />
    <aura:attribute name="topId" type="string" default="tmp" />
    <aura:attribute name="expanded" type="boolean" default="false" />
    <aura:attribute name="treeBody" type="string" description="Contains the body of the tree markup as generated by the JS" />
    <aura:handler name="change" value="{!v.recordId}" action="{!c.init}"/>
    <aura:handler event="aura:locationChange" action="{!c.destroyCmp}"/>
    <ltng:require scripts="/resource/JQuery172, /resource/numeral/adamwdraper-Numeral-js-7487acb/numeral.js, /resource/momentJS" afterScriptsLoaded="{!c.init}" />
    <aura:if isTrue="{!v.topId == v.recordId}" ><aura:if isTrue="{!v.expanded == false}" ><div style="float:right;"><button class="slds-button slds-button_neutral" onclick="{!c.expandAll}">Expand All</button></div></aura:if></aura:if>
    <aura:if isTrue="{!v.expanded == true}" ><div style="float:right;"><button class="slds-button slds-button_neutral" onclick="{!c.collapseAll}">Collapse All</button></div></aura:if>
    
    <ul id="treeContainer"><aura:unescapedHtml value="{!v.treeBody}"/></ul>    
</aura:component>