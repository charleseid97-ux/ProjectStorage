<?xml version="1.0" encoding="UTF-8"?>
<LightningComponentBundle xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>59.0</apiVersion>
    <isExposed>true</isExposed>
    <targets>
        <target>lightning__RecordAction</target>
        <target>lightning__AppPage</target>
        <target>lightning__FlowScreen</target>
    </targets>
    <targetConfigs>
        <targetConfig targets="lightning__RecordAction">
            <actionType>ScreenAction</actionType>
        </targetConfig>
        <targetConfig targets="lightning__FlowScreen">
            <property name="recordId" type="String" label="please enter recordId"/>
            <property name="objectApiName" type="String" label="please enter ObjectAPI name" />
            <property name="quickActionName" label="The quick action that called this flow" type="String" description="The value the user selected in the picklist" />
        </targetConfig>
     </targetConfigs>
</LightningComponentBundle>