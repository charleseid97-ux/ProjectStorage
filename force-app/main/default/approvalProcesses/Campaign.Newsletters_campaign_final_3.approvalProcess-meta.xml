<?xml version="1.0" encoding="UTF-8"?>
<ApprovalProcess xmlns="http://soap.sforce.com/2006/04/metadata">
    <active>false</active>
    <allowRecall>true</allowRecall>
    <allowedSubmitters>
        <type>owner</type>
    </allowedSubmitters>
    <approvalPageFields>
        <field>Name</field>
        <field>Owner</field>
        <field>Type</field>
        <field>Status</field>
        <field>Start_Date_Time__c</field>
        <field>Newsletter_Country__c</field>
        <field>Language__c</field>
        <field>Type_of_client__c</field>
        <field>Description</field>
        <field>Assigned_to__c</field>
    </approvalPageFields>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <approvalActions>
            <action>
                <name>Update_status_campaign_waiting_complianc</name>
                <type>FieldUpdate</type>
            </action>
        </approvalActions>
        <assignedApprover>
            <approver>
                <name>Owner</name>
                <type>relatedUserField</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Approval content by Campaign Owner</label>
        <name>Approval_content_by_Campaign_Owner</name>
        <rejectionActions>
            <action>
                <name>Inform_Marketing_user_that_the_template_is_rejected_by_the_BD_CRM</name>
                <type>Alert</type>
            </action>
            <action>
                <name>MAJ_status_template_to_be_adjusted</name>
                <type>FieldUpdate</type>
            </action>
        </rejectionActions>
    </approvalStep>
    <approvalStep>
        <allowDelegate>false</allowDelegate>
        <assignedApprover>
            <approver>
                <name>lsaychareune.external-crm@carmignac.com</name>
                <type>user</type>
            </approver>
            <whenMultipleApprovers>FirstResponse</whenMultipleApprovers>
        </assignedApprover>
        <label>Approval content by Legal and Compliance</label>
        <name>Approval_content_by_Legal_and_Compliance</name>
        <rejectBehavior>
            <type>RejectRequest</type>
        </rejectBehavior>
    </approvalStep>
    <enableMobileDeviceAccess>false</enableMobileDeviceAccess>
    <entryCriteria>
        <criteriaItems>
            <field>Campaign.Status</field>
            <operation>equals</operation>
            <value>Under Construction</value>
        </criteriaItems>
        <criteriaItems>
            <field>Campaign.RecordType</field>
            <operation>equals</operation>
            <value>Newsletters</value>
        </criteriaItems>
    </entryCriteria>
    <finalApprovalActions>
        <action>
            <name>MAJ_status_template_approved</name>
            <type>FieldUpdate</type>
        </action>
        <action>
            <name>MAJ_Template_approved_checkbox</name>
            <type>FieldUpdate</type>
        </action>
    </finalApprovalActions>
    <finalApprovalRecordLock>true</finalApprovalRecordLock>
    <finalRejectionActions>
        <action>
            <name>MAJ_status_template_to_be_adjusted</name>
            <type>FieldUpdate</type>
        </action>
    </finalRejectionActions>
    <finalRejectionRecordLock>false</finalRejectionRecordLock>
    <initialSubmissionActions>
        <action>
            <name>Update_sales_review</name>
            <type>FieldUpdate</type>
        </action>
    </initialSubmissionActions>
    <label>Newsletters campaign final</label>
    <processOrder>1</processOrder>
    <recordEditability>AdminOrCurrentApprover</recordEditability>
    <showApprovalHistory>true</showApprovalHistory>
</ApprovalProcess>
