<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <fieldUpdates>
        <fullName>User_CopyEmail</fullName>
        <field>TECH_UserEmail__c</field>
        <formula>Email</formula>
        <name>User_CopyEmail</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>User_WF001_CopyBusinessDevRegions</fullName>
        <active>true</active>
        <description>This workflow copies the values of the multipicklist Business Development Regions in a another field used in a Process Builder which populates automatically the business development region when possible.</description>
        <formula>(ISCHANGED( BusinessDevelopmentRegions__c )  || ISNEW()) &amp;&amp; NOT( BypassWorkflowRules__c )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>User_WF002_CopyEmail</fullName>
        <actions>
            <name>User_CopyEmail</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Copy the email adresse on the technical field at the creation or modification</description>
        <formula>( ISNEW() || ISCHANGED(Email))  &amp;&amp;  (Profile.Name  &lt;&gt; &apos;Carmignac - Interface&apos;) &amp;&amp;   NOT( $User.BypassWorkflowRules__c )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
