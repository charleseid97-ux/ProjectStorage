    <rules>
        <fullName>Contact_WF010_WebsiteCreationDate</fullName>
        <actions>
            <name>UpdateWebsiteCreationDate</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <description>Auto update of website creation date when website role is updated by a non technical profile (Business developer, campaign automation, contributor or CRM)</description>
        <formula>AND(
ISCHANGED(WebsiteRole__c),
ISBLANK( WebsiteCreationDate__c ),
OR(
$User.ProfileId = &apos;00e58000000z9go&apos;,
$User.ProfileId = &apos;00e58000000z9gq&apos;,
$User.ProfileId = &apos;00e58000000z9gr&apos;,
$User.ProfileId = &apos;00e58000000z9gp&apos;
))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
