    <rules>
        <fullName>Contact_WF001_CapitalLetterOnLastName</fullName>
        <actions>
            <name>Contact_UpdateFirstNameFirstLetteCapital</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>Contact_updateLastNameCapitalLetter</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Automatique Capital Letter on Last Name</description>
        <formula>AND(     NOT($User.BypassWorkflowRules__c),     OR(        ISNEW(),        ISCHANGED( LastName ),        ISCHANGED( FirstName ),        AND            (ISCHANGED (FirstName),            ISCHANGED (LastName)            )       ) )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
