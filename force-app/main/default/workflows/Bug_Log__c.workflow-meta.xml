    <fieldUpdates>
        <fullName>BugLogsUpdateCloseDate</fullName>
        <description>Update the Close Date field by Today date</description>
        <field>CloseDate__c</field>
        <formula>TODAY()</formula>
        <name>BugLogs_UpdateCloseDate</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Bug_Log_UpdateResultKOStatusPending</fullName>
        <field>Status__c</field>
        <literalValue>Pending CSC</literalValue>
        <name>Bug Log_UpdateResultKOStatusPending</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>BuglogsUpdateStatusClosed</fullName>
        <field>Status__c</field>
        <literalValue>Closed</literalValue>
        <name>BugLogs_UpdateStatusClosed</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Close_date</fullName>
        <description>&quot;Close Date &quot; filed is automatically filled with the &quot;Last Modification Date&quot; when the status of a case goes to close</description>
        <field>CloseDate__c</field>
        <formula>DATEVALUE (LastModifiedDate)</formula>
        <name>Close date</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>true</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>BugLogs_WF001_StatusKO</fullName>
        <actions>
            <name>Bug_Log_UpdateResultKOStatusPending</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Bug_Log__c.RetestResult__c</field>
            <operation>equals</operation>
            <value>KO</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.BypassWorkflowRules__c</field>
            <operation>equals</operation>
            <value>False</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>BugLogs_WF002_StatusOK</fullName>
        <actions>
            <name>BugLogsUpdateCloseDate</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>BuglogsUpdateStatusClosed</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Bug_Log__c.RetestResult__c</field>
            <operation>equals</operation>
            <value>OK</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.BypassWorkflowRules__c</field>
            <operation>equals</operation>
            <value>False</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>BugLogs_WF003_RestestSendAlert</fullName>
        <actions>
            <name>BugLog_HasBeenRetestAnsweredEmailAlert</name>
            <type>Alert</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Bug_Log__c.Status__c</field>
            <operation>equals</operation>
            <value>Re-test /Answered</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.BypassWorkflowRules__c</field>
            <operation>equals</operation>
            <value>False</value>
        </criteriaItems>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>BugLogs_WF004_NewBugLog</fullName>
        <actions>
            <name>BugLog_NewBugCreated</name>
            <type>Alert</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Bug_Log__c.CreatedDate</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>User.BypassWorkflowRules__c</field>
            <operation>equals</operation>
            <value>False</value>
        </criteriaItems>
        <description>Email sent to CSC Team when a new bug is logged</description>
        <triggerType>onCreateOnly</triggerType>
    </rules>
    <rules>
        <fullName>BugLogs_WF005_UserAnswererd</fullName>
        <actions>
            <name>BugLogsUserAnswered</name>
            <type>Alert</type>
        </actions>
        <active>false</active>
        <description>Send an email notification to the &quot;Assigned To&quot; admin when user answered</description>
        <formula>AND(NOT($User.BypassWorkflowRules__c), ISCHANGED( ReTestDetail__c ))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>BugLogs_WF006_BugAssignedToUser</fullName>
        <actions>
            <name>BugLogs_LogAssignedToUser</name>
            <type>Alert</type>
        </actions>
        <active>false</active>
        <description>Send an email alert to notice the user that a new log has been assigned to him</description>
        <formula>AND( NOT($User.BypassWorkflowRules__c), OR(    AND(        ISNEW(),        NOT(ISNULL(AssignedTo__c )),        $User.Id  &lt;&gt;  AssignedTo__r.Id),    AND(        $User.Id  &lt;&gt;  AssignedTo__r.Id ,        ISCHANGED( AssignedTo__c ))    ))</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Easy Log %3A Alert 1 Send email to Alpha Team</fullName>
        <actions>
            <name>Easy_Log_Alert_1_to_Alpha_Admin_log_created</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Bug_Log__c.Status__c</field>
            <operation>equals</operation>
            <value>Open</value>
        </criteriaItems>
        <criteriaItems>
            <field>Bug_Log__c.App__c</field>
            <operation>equals</operation>
            <value>Salesforce</value>
        </criteriaItems>
        <criteriaItems>
            <field>Bug_Log__c.Type__c</field>
            <operation>equals</operation>
            <value>Evolution/Suggestion</value>
        </criteriaItems>
        <description>An email is sent to Alpha Team after a log has been created</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>Easy Log %3A Alert 1 Send email to DS Team</fullName>
        <actions>
            <name>Easy_Log_Alert_1_to_DS_Admin_log_created</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <booleanFilter>1 AND 2</booleanFilter>
        <criteriaItems>
            <field>Bug_Log__c.Status__c</field>
            <operation>equals</operation>
            <value>Open</value>
        </criteriaItems>
        <criteriaItems>
            <field>Bug_Log__c.App__c</field>
            <operation>contains</operation>
            <value>Salesforce,Schedule,etouches,Prospace,Pyramid Sales&amp;Marketing,Tableau Software</value>
        </criteriaItems>
        <description>An email is sent to DS Team after a log has been created</description>
        <triggerType>onCreateOnly</triggerType>
    </rules>
