    <rules>
        <fullName>Easy Log %3A Alert 2 Send Status changed email to Users</fullName>
        <actions>
            <name>Easy_Log_Alert_Email_2_sent_to_User_when_the_Status_is_updated</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <booleanFilter>1</booleanFilter>
        <criteriaItems>
            <field>Bug_Log__c.Status__c</field>
            <operation>contains</operation>
            <value>Ongoing,Pending</value>
        </criteriaItems>
        <description>2nd email sent to user to inform him about any change of the status expect Open and Closed</description>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Easy Log %3A Alert 2 Send emaill Admin when Bug Assigned to</fullName>
        <actions>
            <name>Easy_Log_Alert_2_to_Admin_when_Bug_Assigned</name>
            <type>Alert</type>
        </actions>
        <active>true</active>
        <description>Send an email alert to notice the user that a new log has been assigned to him</description>
        <formula>ISCHANGED( AssignedTo__c )</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Easy Log %3A Alert 4 Send emaill Users when Bug closed</fullName>
        <actions>
            <name>Easy_Log_Alert_Email_4_sent_to_User_when_Case_is_closed</name>
            <type>Alert</type>
        </actions>
        <actions>
            <name>Close_date</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Bug_Log__c.Status__c</field>
            <operation>equals</operation>
            <value>Closed</value>
        </criteriaItems>
        <description>Send an email alert to notice the user that is Bug/log is now closed</description>
        <triggerType>onAllChanges</triggerType>
    </rules>
</Workflow>
