    <rules>
        <fullName>Auto-Activate Newsletter Campaigns</fullName>
        <actions>
            <name>Set_Campaign_to_Activte</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>RecordType.Name = &apos;Newsletters&apos;</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
    <rules>
        <fullName>Campaign_WF001_AutoEndDate</fullName>
        <actions>
            <name>Campaign_AutoEndDateTime</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <description>Automatically put end date time same as start date time (only for Newsletter)</description>
        <formula>OR(
AND(
ischanged( Start_Date_Time__c ),
RecordType.Name = &apos;Newsletters&apos;
),
AND(
isnew(),
RecordType.Name = &apos;Newsletters&apos;)
)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Campaign_WF002_IsActive</fullName>
        <actions>
            <name>Campaign_Active</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>InitContactListConfirmedCheckbox</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>InitNewsletterApprovedCheckbox</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Campaign.RecordTypeId</field>
            <operation>equals</operation>
            <value>Newsletters</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.BypassWorkflowRules__c</field>
            <operation>equals</operation>
            <value>False</value>
        </criteriaItems>
        <description>Always put campaign as active when created</description>
        <triggerType>onCreateOnly</triggerType>
    </rules>
    <rules>
        <fullName>Campaign_WF003_NewsletterInactiveafter60days</fullName>
        <actions>
            <name>Update_Unactive_Campaign</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <criteriaItems>
            <field>Campaign.RecordTypeId</field>
            <operation>equals</operation>
            <value>Newsletters</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.BypassWorkflowRules__c</field>
            <operation>equals</operation>
            <value>False</value>
        </criteriaItems>
        <description>60 days after the end date and time, the campaign is unactive (unactive is use for Pardot + Report)</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
        <workflowTimeTriggers>
            <offsetFromField>Campaign.End_Date_Time__c</offsetFromField>
            <timeLength>60</timeLength>
            <workflowTimeTriggerUnit>Days</workflowTimeTriggerUnit>
        </workflowTimeTriggers>
    </rules>
    <rules>
        <fullName>Record Time of Compliance Approval for Newsletters</fullName>
        <actions>
            <name>Update_Date_of_Approval</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <formula>Approved_by_Compliance__c = TRUE</formula>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
    </rules>
</Workflow>
