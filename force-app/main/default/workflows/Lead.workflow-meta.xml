<?xml version="1.0" encoding="UTF-8"?>
<Workflow xmlns="http://soap.sforce.com/2006/04/metadata">
    <alerts>
        <fullName>Email_to_notify_the_new_owner_of_the_leas</fullName>
        <description>Email to notify the new owner of the lead</description>
        <protected>false</protected>
        <recipients>
            <type>owner</type>
        </recipients>
        <senderType>CurrentUser</senderType>
        <template>unfiled$public/LeadsNewassignmentnotificationSAMPLE</template>
    </alerts>
    <fieldUpdates>
        <fullName>Lead_TrialSetToExpired</fullName>
        <description>Set Trial Status to Expired</description>
        <field>TrialStatus__c</field>
        <literalValue>1</literalValue>
        <name>Lead_TrialSetToExpired</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Lead_UpdateTechExternalId</fullName>
        <field>TECH_WebSiteID__c</field>
        <formula>Id</formula>
        <name>Lead_UpdateTechExternalId</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Formula</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>SetTrialStatusToNone</fullName>
        <description>Empty field Trial Status</description>
        <field>TrialStatus__c</field>
        <name>SetTrialStatusToNone</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>SetWesiteRoleToNoProfile</fullName>
        <description>Set Website Role to &quot;no profile&quot;</description>
        <field>WebsiteRole__c</field>
        <literalValue>1</literalValue>
        <name>SetWesiteRoleToNoProfile</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <fieldUpdates>
        <fullName>Set_CVENT_as_Source</fullName>
        <field>LeadSource</field>
        <literalValue>Event</literalValue>
        <name>Set CVENT as Source</name>
        <notifyAssignee>false</notifyAssignee>
        <operation>Literal</operation>
        <protected>false</protected>
        <reevaluateOnChange>false</reevaluateOnChange>
    </fieldUpdates>
    <rules>
        <fullName>Assign Event as Lead Source</fullName>
        <actions>
            <name>Set_CVENT_as_Source</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Lead.CventEvents__ContactStub__c</field>
            <operation>notEqual</operation>
        </criteriaItems>
        <criteriaItems>
            <field>Lead.LeadSource</field>
            <operation>notEqual</operation>
            <value>BrightTalk,Business Card,CSN Webinar,DOOR,Event,Phone Inquiry,Press &amp; Media,Purchased List,Referral,Social Media,Website</value>
        </criteriaItems>
        <description>Workflow rule to populate Lead Source for CVENT records</description>
        <triggerType>onCreateOnly</triggerType>
    </rules>
    <rules>
        <fullName>Lead_WF001_CopyId</fullName>
        <actions>
            <name>Lead_UpdateTechExternalId</name>
            <type>FieldUpdate</type>
        </actions>
        <active>false</active>
        <formula>(ISNEW()  || (  NOT(ISNEW()) &amp;&amp;  ISBLANK(TECH_WebSiteID__c)))  &amp;&amp;  NOT( $User.BypassWorkflowRules__c)</formula>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Lead_WF002_CancelWebsite</fullName>
        <actions>
            <name>SetTrialStatusToNone</name>
            <type>FieldUpdate</type>
        </actions>
        <actions>
            <name>SetWesiteRoleToNoProfile</name>
            <type>FieldUpdate</type>
        </actions>
        <active>true</active>
        <criteriaItems>
            <field>Lead.Status</field>
            <operation>equals</operation>
            <value>Disqualified</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.BypassWorkflowRules__c</field>
            <operation>equals</operation>
            <value>False</value>
        </criteriaItems>
        <description>Website role is set to &quot;No Profile&quot; and trial status = null if lead is disqualified</description>
        <triggerType>onAllChanges</triggerType>
    </rules>
    <rules>
        <fullName>Lead_WF003_TrialPeriod</fullName>
        <active>false</active>
        <criteriaItems>
            <field>Lead.WebsiteRole__c</field>
            <operation>equals</operation>
            <value>5</value>
        </criteriaItems>
        <criteriaItems>
            <field>Lead.TrialStatus__c</field>
            <operation>equals</operation>
            <value>5,4</value>
        </criteriaItems>
        <criteriaItems>
            <field>User.BypassWorkflowRules__c</field>
            <operation>equals</operation>
            <value>False</value>
        </criteriaItems>
        <description>Set Trial Status to &quot;Expired&quot; when Website Creation Date + 30 days is reached AND Website Role is &quot;ProSpace Temp&quot; AND Trial Status is &quot;Waiting for Validation&quot;</description>
        <triggerType>onCreateOrTriggeringUpdate</triggerType>
        <workflowTimeTriggers>
            <actions>
                <name>Lead_TrialSetToExpired</name>
                <type>FieldUpdate</type>
            </actions>
            <offsetFromField>Lead.WebsiteCreationDate__c</offsetFromField>
            <timeLength>30</timeLength>
            <workflowTimeTriggerUnit>Days</workflowTimeTriggerUnit>
        </workflowTimeTriggers>
    </rules>
</Workflow>
