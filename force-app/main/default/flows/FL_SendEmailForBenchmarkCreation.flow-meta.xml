        <name>EmailBody</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;Hello Investment Performance Team,&lt;/span&gt;&lt;/p&gt;&lt;p&gt;As part of the project &lt;strong&gt;{!$Record.ProjectProductParent__r.Name}&lt;/strong&gt;, a Benchmark must now be linked in Salesforce to complete the &lt;strong&gt;SetUp phase&lt;/strong&gt;.&lt;/p&gt;&lt;p&gt;The required Benchmark name defined by Product Strategy is:&amp;nbsp;&lt;strong&gt;&amp;nbsp;{!$Record.ProjectProductParent__r.BenchmarkName__c}&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Please follow the steps below:&lt;/p&gt;&lt;ol&gt;&lt;li&gt;Open the project here: &lt;a href=&quot;{!ParentRecordLink}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;Access the project in Salesforce&lt;/a&gt;&lt;/li&gt;&lt;li&gt;In the &lt;strong&gt;SetUp&lt;/strong&gt; phase, select the Benchmark using the name provided.&lt;/li&gt;&lt;li&gt;If the Benchmark does not exist yet, please create it first using the following &lt;a href=&quot;{!BenchmarkLink}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;&lt;strong&gt;link&lt;/strong&gt;&lt;/a&gt;&lt;strong&gt;.&lt;/strong&gt;&lt;/li&gt;&lt;li&gt;The benchmark will be automatically linked to the project.&lt;/li&gt;&lt;li&gt;Once the Benchmark is linked to the project, make sure to &lt;strong&gt;validate the SetUp phase&lt;/strong&gt;.&lt;/li&gt;&lt;/ol&gt;&lt;p&gt;Thank you for your support,&lt;/p&gt;&lt;p&gt;The Product Strategy team&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>EmailSubject</name>
