        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;span style=&quot;color: black; font-family: &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 10.5pt;&quot;&gt;Dear &lt;/span&gt;&lt;span style=&quot;color: rgb(68, 68, 68); background-color: rgb(255, 255, 255);&quot;&gt;{!$Record.ContactOwner__c},&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: black; font-family: &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 10.5pt;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: black; font-family: &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 10.5pt;&quot;&gt;We have received an &lt;/span&gt;&lt;strong style=&quot;color: black; font-family: &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 10.5pt;&quot;&gt;Invitation opt-out request&lt;/strong&gt;&lt;span style=&quot;color: black; font-family: &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 10.5pt;&quot;&gt; from &lt;/span&gt;&lt;a href=&quot;{!RecordURL}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;color: black; font-family: &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 10.5pt;&quot;&gt;{!$Record.FirstName} {!$Record.LastName}&lt;/a&gt;&lt;span style=&quot;color: black; font-family: &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 10.5pt;&quot;&gt; (email address: {!$Record.Email}) at {!$Flow.CurrentDateTime}.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: black; font-family: &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 10.5pt;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: black; font-family: &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 10.5pt;&quot;&gt;This has a direct implication on their receipt of our future event invitations, as they will no longer receive these communications from us.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;color: black; font-family: &amp;quot;Segoe UI&amp;quot;, sans-serif; font-size: 10.5pt;&quot;&gt;&amp;nbsp;&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&