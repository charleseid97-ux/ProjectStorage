<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <name>Send_IS_Email</name>
        <label>Send IS Email</label>
        <locationX>176</locationX>
        <locationY>323</locationY>
        <actionName>emailSimple</actionName>
        <actionType>emailSimple</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>emailAddresses</name>
            <value>
                <stringValue>benoit.nansot@carmignac.com</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>senderType</name>
            <value>
                <stringValue>OrgWideEmailAddress</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>senderAddress</name>
            <value>
                <elementReference>$Label.NoReplayWideAddress</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailSubject</name>
            <value>
                <elementReference>ISEmailSubject</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailBody</name>
            <value>
                <elementReference>ISEmailBody</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>sendRichBody</name>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputParameters>
        <nameSegment>emailSimple</nameSegment>
    </actionCalls>
    <apiVersion>59.0</apiVersion>
    <description>Send an email to investment solutions when an opportunity reached co-design stage and an IS agreement is linked</description>
    <environments>Default</environments>
    <formulas>
        <name>AccountURL</name>
        <dataType>String</dataType>
        <expression>LEFT( {!$Api.Enterprise_Server_URL_520}, FIND( &apos;/services&apos;, {!$Api.Enterprise_Server_URL_520} ))&amp;{!$Record.Account.Id}</expression>
    </formulas>
    <formulas>
        <name>OpportunityURL</name>
        <dataType>String</dataType>
        <expression>LEFT( {!$Api.Enterprise_Server_URL_520}, FIND( &apos;/services&apos;, {!$Api.Enterprise_Server_URL_520} ))&amp;{!$Record.Id}</expression>
    </formulas>
    <interviewLabel>FL_AfterSav {!$Flow.CurrentDateTime}</interviewLabel>
    <label>FL_After Save IS Co-Design Email Alert</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>50</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Send_IS_Email</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterLogic>and</filterLogic>
        <filters>
            <field>StageName</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>Co-Design</stringValue>
            </value>
        </filters>
        <filters>
            <field>RecordTypeId</field>
            <operator>EqualTo</operator>
            <value>
                <stringValue>0121i000000cBJkAAM</stringValue>
            </value>
        </filters>
        <filters>
            <field>Agreement__c</field>
            <operator>IsNull</operator>
            <value>
                <booleanValue>false</booleanValue>
            </value>
        </filters>
        <object>Opportunity</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <textTemplates>
        <name>ISEmailBody</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Dear Investment Solutions Team,&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;The Opportunity &lt;a href=&quot;{!OpportunityURL}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;{!$Record.Name}&lt;/a&gt; has reached the co-design stage and been linked with the following Agreement : {!$Record.Agreement__r.ConventionName__c}.&lt;/p&gt;&lt;p&gt;Please see below the highlights or click on the Opporunity name to see the full record in Salesforce :&lt;/p&gt;&lt;p&gt;Company Name : &lt;a href=&quot;{!OpportunityURL}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;{!$Record.Account.Name}&lt;/a&gt;&lt;/p&gt;&lt;p&gt;Close Date : {!$Record.CloseDate}&lt;/p&gt;&lt;p&gt;Amount : &lt;span style=&quot;color: rgb(68, 68, 68); background-color: rgb(255, 255, 255);&quot;&gt;{!$Record.CurrencyIsoCode} &lt;/span&gt;{!$Record.Amount}&lt;/p&gt;&lt;p&gt;Opportunity Owner :  {!$Record.Owner.FirstName} {!$Record.Owner.LastName}&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;&lt;p&gt;Kind regards,&lt;/p&gt;&lt;p&gt;Salesforce Support&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>ISEmailSubject</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>The Agreement {!$Record.Agreement__r.ConventionName__c} has been linked to an Opportunity</text>
    </textTemplates>
</Flow>
