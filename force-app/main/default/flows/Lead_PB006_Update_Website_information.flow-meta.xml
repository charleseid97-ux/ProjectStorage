    <description>Copy the fields from the detail section into the Website Information section</description>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND(!$User.BypassProcessBuilders__c,
        !ISBLANK( [Lead].TECH_WebSiteID__c ) ,
	!ISPICKVAL([Lead].Synchrostatus__c , &quot;To be synced&quot;), 
	OR(
		ISCHANGED([Lead].Salutation),
		ISCHANGED([Lead].LastName), 
		ISCHANGED([Lead].FirstName), 
		ISCHANGED([Lead].Street), 
		ISCHANGED([Lead].Country), 
		ISCHANGED([Lead].PostalCode), 
		ISCHANGED([Lead].City), 
		ISCHANGED([Lead].Company), 
		ISCHANGED([Lead].Business_Card_Title__c),
                ISCHANGED([Lead].Phone),
                ISCHANGED([Lead].MobilePhone),
                ISCHANGED([Lead].Language__c),
ISCHANGED([Lead].Prospace_Status__c),
ISCHANGED([Lead].WebsiteCountry__c),
ISCHANGED([Lead].WebsiteLanguage__c)

	)
)</stringValue>
            </value>
        </processMetadataValues>
        <name>formula_myRule_1</name>
        <dataType>Boolean</dataType>
        <expression>AND(!{!$User.BypassProcessBuilders__c},
        !ISBLANK( {!myVariable_current.TECH_WebSiteID__c} ) ,
	!ISPICKVAL({!myVariable_current.Synchrostatus__c} , &quot;To be synced&quot;), 
	OR(
		ISCHANGED({!myVariable_current.Salutation}),
		ISCHANGED({!myVariable_current.LastName}), 
		ISCHANGED({!myVariable_current.FirstName}), 
		ISCHANGED({!myVariable_current.Street}), 
		ISCHANGED({!myVariable_current.Country}), 
		ISCHANGED({!myVariable_current.PostalCode}), 
		ISCHANGED({!myVariable_current.City}), 
		ISCHANGED({!myVariable_current.Company}), 
		ISCHANGED({!myVariable_current.Business_Card_Title__c}),
                ISCHANGED({!myVariable_current.Phone}),
                ISCHANGED({!myVariable_current.MobilePhone}),
                ISCHANGED({!myVariable_current.Language__c}),
ISCHANGED({!myVariable_current.Prospace_Status__c}),
ISCHANGED({!myVariable_current.WebsiteCountry__c}),
ISCHANGED({!myVariable_current.WebsiteLanguage__c})

	)
)</expression>
    </formulas>
