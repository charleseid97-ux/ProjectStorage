    </textTemplates>
    <textTemplates>
        <name>ClosedEmailBody</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Hi Team,&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;The project&amp;nbsp;&lt;/span&gt;&lt;a href=&quot;{!recordlink}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;font-size: 14px;&quot;&gt;&lt;strong&gt;{!$Record.Name} &lt;/strong&gt;&lt;/a&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt; has now been &lt;/span&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;closed &lt;/strong&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;in Salesforce.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;All data contributed during the project is now available in the &lt;/span&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;Product Catalog&lt;/strong&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;&lt;u&gt;KEY INFO&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;Type of project :&amp;nbsp;&lt;/strong&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;{!$Record.RecordType.Name}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;Go Live Date : &lt;/strong&gt;&lt;span style=&quot;font-size: 14px; background-color: rgb(255, 255, 255);&quot;&gt;{!$Record.EndDate__c}&lt;/span&gt;&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;On the &lt;/span&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;morning of the Go Live Date&lt;/strong&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;, all data managed in PMT during the project was &lt;/span&gt;&lt;strong style=&quot;font-size: 14px;&quot;&gt;automatically injected into the Product Catalog&lt;/strong&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;. This transfer ensures that the Product Catalog now reflects the final validated data from the project.&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;Thank you for your collaboration,&lt;/span&gt;&lt;/p&gt;&lt;p&gt;&lt;span style=&quot;font-size: 14px;&quot;&gt;The Product Strategy Team&lt;/span&gt;&lt;/p&gt;</text>
    </textTemplates>
