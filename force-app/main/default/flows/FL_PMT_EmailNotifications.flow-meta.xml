    <textTemplates>
        <name>ActivationEmailBody</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Hi Team,&lt;/p&gt;&lt;p&gt;The project &lt;strong&gt;{!$Record.Name}&lt;/strong&gt; is now activated in Salesforce.&lt;/p&gt;&lt;p&gt;You can start contributing by reviewing your assigned fields and tasks.&lt;/p&gt;&lt;p&gt;&lt;strong&gt;&lt;u&gt;KEY INFO&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Type:&lt;/strong&gt; {!$Record.RecordType.Name}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Estimated Launch Date:&lt;/strong&gt; {!$Record.EndDate__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Description:&lt;/strong&gt; {!$Record.ProductDescription__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Next Milestone:&lt;/strong&gt; {!GetMileStones.Name} – {!GetMileStones.StartDate__c}&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;strong&gt;&lt;u&gt;REMINDER&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Please assign the &lt;strong&gt;Team Owner&lt;/strong&gt; for this project in Salesforce — only the designated owner will receive Teams notifications.&lt;/p&gt;&lt;p&gt;&lt;a href=&quot;{!recordlink}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot; style=&quot;color: rgb(1, 118, 211);&quot;&gt;&lt;strong&gt;ACCESS THE PROJECT IN SALESFORCE&lt;/strong&gt;&lt;/a&gt;&lt;/p&gt;&lt;p&gt;Thank you,&lt;/p&gt;&lt;p&gt;&lt;strong&gt;The Product Strategy Team&lt;/strong&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>ActivationEmailBodyModification</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Hi Team,&lt;/p&gt;&lt;p&gt;The modification project called &lt;a href=&quot;{!recordlink}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;{!$Record.Name}&lt;/a&gt; is now activated in Salesforce. You are receiving this notification because your team may review and validate specific updates related to this modification.&lt;/p&gt;&lt;p&gt;&lt;strong&gt;&lt;u&gt;KEY INFO&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;ul&gt;&lt;li&gt;&lt;strong&gt;Type:&lt;/strong&gt; &lt;span style=&quot;background-color: rgb(255, 255, 255);&quot;&gt;{!$Record.RecordType.Name}&lt;/span&gt;&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Estimated Launch Date:&lt;/strong&gt; {!$Record.EndDate__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Description:&lt;/strong&gt; {!$Record.ProductDescription__c}&lt;/li&gt;&lt;li&gt;&lt;strong&gt;Next Milestone:&lt;/strong&gt; {!GetMileStones.Name} – {!GetMileStones.StartDate__c}&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;&lt;strong&gt;&lt;u&gt;INVOLVED TEAMS in the modification&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;{!teamsReturned}&lt;/p&gt;&lt;p&gt;&lt;strong&gt;&lt;u&gt;REMINDER&lt;/u&gt;&lt;/strong&gt;&lt;/p&gt;&lt;p&gt;Please make sure the &lt;strong&gt;Team Owner&lt;/strong&gt;  is assigned in Salesforce — only the designated Team Owner will receive future Teams notifications for this project.&lt;/p&gt;&lt;p&gt;&lt;a href=&quot;{!recordlink} &quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;ACCESS THE PROJECT IN SALESFORCE&lt;/a&gt;&lt;/p&gt;&lt;p&gt;Thank you,&lt;/p&gt;&lt;p&gt;&lt;strong&gt;The Product Strategy Team&lt;/strong&gt;&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>ActivationEmailSubject</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
