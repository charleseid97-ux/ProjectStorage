    <recordUpdates>
        <description>update website email and triger website synch</description>
        <name>Update_Website_Login</name>
        <label>Update Website Login</label>
        <locationX>314</locationX>
        <locationY>431</locationY>
        <inputAssignments>
            <field>Synchrostatus__c</field>
            <value>
                <stringValue>To be synced</stringValue>
            </value>
        </inputAssignments>
        <inputAssignments>
            <field>WebsiteLogin__c</field>
            <value>
                <elementReference>$Record.Email</elementReference>
            </value>
        </inputAssignments>
        <inputReference>$Record</inputReference>
    </recordUpdates>
    <start>
        <locationX>188</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Email_Update</targetReference>
        </connector>
        <filterFormula>OR (
AND( 
NOT(ISBLANK({!$Record.WebsiteLogin__c})),
{!$Record__Prior.Email} = {!$Record__Prior.WebsiteLogin__c}, 
ISCHANGED({!$Record.Email})),
AND({!$User.LastName} = &apos;ProSpace&apos;,
{!$Record.WebsiteLogin__c} &lt;&gt; {!$Record__Prior.WebsiteLogin__c}
)
)</filterFormula>
        <object>Contact</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Draft</status>
    <textTemplates>
        <name>EmailBody</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Dear CRM Team,&lt;/p&gt;&lt;p&gt;Please note that the Contact &lt;a href=&quot;{!RecordLink}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;{!$Record.First_Last_name__c}&lt;/a&gt; has changed their ProSpace Website Login&lt;/p&gt;&lt;p&gt;It is recommenced to check this new email and if necessary update the contact&apos;s main email address.&lt;/p&gt;&lt;p&gt;Kind regards,&lt;/p&gt;&lt;p&gt;Salesforce Support&lt;/p&gt;&lt;p&gt;&lt;br&gt;&lt;/p&gt;</text>
    </textTemplates>
</Flow>
