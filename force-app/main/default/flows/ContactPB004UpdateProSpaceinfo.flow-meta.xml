    <description>Copy the fields from the detail section into the Website Information section</description>
    <formulas>
        <processMetadataValues>
            <name>originalFormula</name>
            <value>
                <stringValue>AND(!$User.BypassProcessBuilders__c,
	!ISPICKVAL([Contact].Synchrostatus__c , &quot;&quot;), 
        $User.LastName &lt;&gt; &quot;ProSpace&quot; ,
        !ISNEW(),
	!ISPICKVAL([Contact].Synchrostatus__c , &quot;To be synced&quot;), 
	OR(
		ISCHANGED([Contact].WebsiteSalutation__c),
		ISCHANGED([Contact].FirstNameWebsite__c), 
		ISCHANGED([Contact].LastNameWebsite__c), 
		ISCHANGED([Contact].WebsiteJobTitle__c), 
		ISCHANGED([Contact].WebsiteCompany__c), 
		ISCHANGED([Contact].WebsiteLogin__c),
                ISCHANGED([Contact].Language__c),
                ISCHANGED([Contact].WebsiteLanguage__c),
                ISCHANGED([Contact].WebsiteCountry__c),
                ISCHANGED([Contact].Address1__c),
                ISCHANGED([Contact].City__c),
                ISCHANGED([Contact].PostalCode__c),
                ISCHANGED([Contact].Country__c),
                ISCHANGED([Contact].PhoneNumber__c),
                ISCHANGED([Contact].ContactStatus__c)
	)
)</stringValue>
            </value>
        </processMetadataValues>
        <name>formula_myRule_1</name>
        <dataType>Boolean</dataType>
        <expression>AND(!{!$User.BypassProcessBuilders__c},
	!ISPICKVAL({!myVariable_current.Synchrostatus__c} , &quot;&quot;), 
        {!$User.LastName} &lt;&gt; &quot;ProSpace&quot; ,
        !ISNEW(),
	!ISPICKVAL({!myVariable_current.Synchrostatus__c} , &quot;To be synced&quot;), 
