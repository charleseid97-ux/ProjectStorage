<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <apiVersion>64.0</apiVersion>
    <description>Record Triggered Flow AfterCreate After Update</description>
    <environments>Default</environments>
    <interviewLabel>VideoCall_AfterCreateAfterUpdate {!$Flow.CurrentDateTime}</interviewLabel>
    <label>VideoCall_AfterCreateAfterUpdate</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Generate_PlatformEvent</targetReference>
        </connector>
        <doesRequireRecordChangedToMeetCriteria>true</doesRequireRecordChangedToMeetCriteria>
        <filterFormula>!ISNULL({!$Record.IntelligenceScore})</filterFormula>
        <object>VideoCall</object>
        <recordTriggerType>Update</recordTriggerType>
        <triggerType>RecordAfterSave</triggerType>
    </start>
    <status>Active</status>
    <subflows>
        <description>Generates a platform event for the VideoCall</description>
        <name>Generate_PlatformEvent</name>
        <label>Generate PlatformEvent</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <flowName>AL_VideoCall_GeneratePlatformEvent</flowName>
        <inputAssignments>
            <name>VideoCallId</name>
            <value>
                <elementReference>$Record.Id</elementReference>
            </value>
        </inputAssignments>
    </subflows>
</Flow>
