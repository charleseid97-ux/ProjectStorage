    &quot;One week&quot;, $Flow.CurrentDate - 7,
    &quot;One Month&quot;, ADDMONTHS($Flow.CurrentDate, -1),
    &quot;One month&quot;, ADDMONTHS($Flow.CurrentDate, -1),
    &quot;Three Months&quot;, ADDMONTHS($Flow.CurrentDate, -3),
