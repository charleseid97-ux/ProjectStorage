        <locationX>528</locationX>
        <locationY>350</locationY>
        <assignmentItems>
            <assignToReference>$Output.Prompt</assignToReference>
            <operator>Add</operator>
            <value>
                <stringValue>
{!ClientInterestCounter}- Company: {!Loop_over_clis.MeetingNote__r.CompanyName__c}
Country: {!Loop_over_clis.MeetingNote__r.Company__r.BillingCountry}
Meeting Name: {!Loop_over_clis.MeetingNote__r.Name}
Meeting Note Id: {!Loop_over_clis.MeetingNote__c}
Notes: {!Loop_over_clis.MeetingNote__r.Note__c}
Date: {!Loop_over_clis.MeetingNote__r.Date__c}
Interest: {!Loop_over_clis.Interest__c}/5
</stringValue>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Assign_Meeting_notes</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Assign_Meeting_notes</name>
        <label>Assign Meeting notes</label>
        <locationX>528</locationX>
        <locationY>458</locationY>
        <assignmentItems>
            <assignToReference>ClientInterestCounter</assignToReference>
            <operator>Add</operator>
            <value>
                <numberValue>1.0</numberValue>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>LastDateMeetingNotes</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_over_clis.MeetingNote__r.Date__c</elementReference>
            </value>
        </assignmentItems>
        <assignmentItems>
            <assignToReference>MeetingNoteCollection</assignToReference>
            <operator>Add</operator>
            <value>
                <elementReference>Loop_over_clis.MeetingNote__r.Company__r.Team__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Break_if_more_than_80</targetReference>
        </connector>
    </assignments>
    <assignments>
        <name>Get_first_date</name>
        <label>Get first date</label>
        <locationX>528</locationX>
        <locationY>674</locationY>
        <assignmentItems>
            <assignToReference>FirstDateMeetingNotes</assignToReference>
            <operator>Assign</operator>
            <value>
                <elementReference>Loop_over_clis.MeetingNote__r.Date__c</elementReference>
            </value>
        </assignmentItems>
        <connector>
            <targetReference>Loop_over_clis</targetReference>
        </connector>
    </assignments>
    <constants>
        <name>FirstDate</name>
        <dataType>String</dataType>
    </constants>
    <decisions>
        <name>Break_if_more_than_80</name>
        <label>Break if more than 80</label>
        <locationX>528</locationX>
        <locationY>566</locationY>
        <defaultConnector>
            <targetReference>Loop_over_clis</targetReference>
        </defaultConnector>
        <defaultConnectorLabel>Default Outcome</defaultConnectorLabel>
        <rules>
            <name>Break</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ClientInterestCounter</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>80.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <isGoTo>true</isGoTo>
                <targetReference>Add_nb_of_MNs_to_prompt</targetReference>
            </connector>
            <label>Break</label>
        </rules>
        <rules>
            <name>If_counter_2</name>
            <conditionLogic>and</conditionLogic>
            <conditions>
                <leftValueReference>ClientInterestCounter</leftValueReference>
                <operator>EqualTo</operator>
                <rightValue>
                    <numberValue>2.0</numberValue>
                </rightValue>
            </conditions>
            <connector>
                <targetReference>Get_first_date</targetReference>
            </connector>
            <label>If counter = 2</label>
        </rules>
    </decisions>
