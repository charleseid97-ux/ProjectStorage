<?xml version="1.0" encoding="UTF-8"?>
<Flow xmlns="http://soap.sforce.com/2006/04/metadata">
    <actionCalls>
        <name>Send_Notification</name>
        <label>Send Notification</label>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <actionName>emailSimple</actionName>
        <actionType>emailSimple</actionType>
        <flowTransactionModel>CurrentTransaction</flowTransactionModel>
        <inputParameters>
            <name>emailAddresses</name>
            <value>
                <elementReference>emailDistributionList</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>senderType</name>
            <value>
                <stringValue>OrgWideEmailAddress</stringValue>
            </value>
        </inputParameters>
        <inputParameters>
            <name>senderAddress</name>
            <value>
                <elementReference>$Label.NoReplayWideAddress</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailSubject</name>
            <value>
                <elementReference>EmailSubject_Launch7Days</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>emailBody</name>
            <value>
                <elementReference>EmailBody_ProjectNotReady</elementReference>
            </value>
        </inputParameters>
        <inputParameters>
            <name>sendRichBody</name>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </inputParameters>
        <nameSegment>emailSimple</nameSegment>
        <offset>0</offset>
    </actionCalls>
    <apiVersion>64.0</apiVersion>
    <description>This flow triggers when a project’s **Launch Date is in 7 days, the Launch milestone is not complete, and some phases are still incomplete.
It alerts Product Strategy to review the project before the automatic batch launch.</description>
    <environments>Default</environments>
    <formulas>
        <name>emailDistributionList</name>
        <dataType>String</dataType>
        <expression>&apos;salesforcesupport@carmignac.com&apos;&amp;&apos;,&apos;&amp;&apos;productstrategy@carmignac.com&apos;</expression>
    </formulas>
    <formulas>
        <name>emailTEST</name>
        <dataType>String</dataType>
        <expression>  &apos;thomas.coullon@carmignac.com,salesforcesupport@carmignac.com&apos;</expression>
    </formulas>
    <formulas>
        <name>ProjectLink</name>
        <dataType>String</dataType>
        <expression>LEFT( {!$Api.Partner_Server_URL_520}, FIND( &apos;/services&apos;, {!$Api.Partner_Server_URL_520} ))&amp;{!$Record.Id}</expression>
    </formulas>
    <interviewLabel>7 days before Notification {!$Flow.CurrentDateTime}</interviewLabel>
    <label>PMT - Email Notification - Launch in 7 days</label>
    <processMetadataValues>
        <name>BuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>CanvasMode</name>
        <value>
            <stringValue>AUTO_LAYOUT_CANVAS</stringValue>
        </value>
    </processMetadataValues>
    <processMetadataValues>
        <name>OriginBuilderType</name>
        <value>
            <stringValue>LightningFlowBuilder</stringValue>
        </value>
    </processMetadataValues>
    <processType>AutoLaunchedFlow</processType>
    <start>
        <locationX>0</locationX>
        <locationY>0</locationY>
        <connector>
            <targetReference>Send_Notification</targetReference>
        </connector>
        <filterLogic>and</filterLogic>
        <filters>
            <field>Send_Notification__c</field>
            <operator>EqualTo</operator>
            <value>
                <booleanValue>true</booleanValue>
            </value>
        </filters>
        <object>ProjectProduct__c</object>
        <schedule>
            <frequency>Daily</frequency>
            <startDate>2025-07-28</startDate>
            <startTime>09:00:00.000Z</startTime>
        </schedule>
        <triggerType>Scheduled</triggerType>
    </start>
    <status>Active</status>
    <textTemplates>
        <name>EmailBody_ProjectNotReady</name>
        <isViewedAsPlainText>false</isViewedAsPlainText>
        <text>&lt;p&gt;Dear all,&lt;/p&gt;&lt;p&gt;The project &lt;a href=&quot;{!ProjectLink}&quot; rel=&quot;noopener noreferrer&quot; target=&quot;_blank&quot;&gt;&lt;strong&gt;{!$Record.Name}&lt;/strong&gt;&lt;/a&gt; is scheduled to launch in &lt;strong&gt;7 days&lt;/strong&gt;.&lt;/p&gt;&lt;p&gt;However, the required conditions to &lt;strong&gt;copy data from PMT to Product Catalog&lt;/strong&gt; are &lt;strong&gt;not met&lt;/strong&gt;:&lt;/p&gt;&lt;ul&gt;&lt;li&gt;The &lt;strong&gt;Milestone Launch Date&lt;/strong&gt; has &lt;strong&gt;not been completed&lt;/strong&gt;.&lt;/li&gt;&lt;li&gt;&lt;strong&gt;All project phases are not marked as complete&lt;/strong&gt;.&lt;/li&gt;&lt;/ul&gt;&lt;p&gt;Please take the necessary actions &lt;strong&gt;as soon as possible&lt;/strong&gt; to ensure the data is ready &lt;strong&gt;ahead of the launch&lt;/strong&gt;.&lt;/p&gt;&lt;p&gt;Best regards,&amp;nbsp;&amp;nbsp;&lt;/p&gt;&lt;p&gt;The PMT Team&lt;/p&gt;</text>
    </textTemplates>
    <textTemplates>
        <name>EmailSubject_Launch7Days</name>
        <isViewedAsPlainText>true</isViewedAsPlainText>
        <text>Warning: {!$Record.Name} cannot be launched in current state (7 days to go)</text>
    </textTemplates>
</Flow>
