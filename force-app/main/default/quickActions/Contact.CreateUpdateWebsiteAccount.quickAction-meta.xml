    <fieldOverrides>
        <field>Address1__c</field>
        <formula>IF(ISBLANK( Contact.Address1__c), Contact.MailingStreet, Contact.Address1__c)</formula>
    </fieldOverrides>
    <fieldOverrides>
        <field>City__c</field>
        <formula>IF(ISBLANK(Contact.City__c), Contact.MailingCity, Contact.City__c)</formula>
    </fieldOverrides>
    <fieldOverrides>
        <field>Country__c</field>
        <formula>IF(ISPICKVAL(Contact.Country__c, &apos;&apos;), TEXT(Contact.MailingCountryCode), TEXT(Contact.Country__c))</formula>
    </fieldOverrides>
    <fieldOverrides>
        <field>FirstNameWebsite__c</field>
