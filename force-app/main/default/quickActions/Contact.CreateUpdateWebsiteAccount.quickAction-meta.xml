    </fieldOverrides>
    <fieldOverrides>
        <field>WebsiteJobTitle__c</field>
        <formula>IF(ISBLANK( Contact.WebsiteJobTitle__c), Contact.Business_Card_Title__c, Contact.WebsiteJobTitle__c)</formula>
    </fieldOverrides>
    <fieldOverrides>
        <field>WebsiteLogin__c</field>
        <formula>IF(ISBLANK(Contact.WebsiteLogin__c), Contact.Email, Contact.WebsiteLogin__c)</formula>
    </fieldOverrides>
    <fieldOverrides>
        <field>WebsiteSalutation__c</field>
        <formula>IF(ISPICKVAL(Contact.WebsiteSalutation__c, &apos;&apos;), TEXT(Contact.Salutation), TEXT(Contact.WebsiteSalutation__c))</formula>
    </fieldOverrides>
