<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Check_Hierarchy_BuissRegion__c</fullName>
    <description>Returns 1 if the Buisness Region of a Company is equal to the Business Region of the parent</description>
    <externalId>false</externalId>
    <formula>if( TEXT(BusinessDevelopmentRegion__c) =  TEXT(Parent.BusinessDevelopmentRegion__c) ,1,0)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>Check Hierarchy BuissRegion</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
