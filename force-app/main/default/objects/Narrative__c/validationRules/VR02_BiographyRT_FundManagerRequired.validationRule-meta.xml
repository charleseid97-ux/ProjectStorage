<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR02_BiographyRT_FundManagerRequired</fullName>
    <active>true</active>
    <errorConditionFormula>AND(NOT($User.BypassValidationRules__c),
RecordType.DeveloperName = &apos;Biography&apos;,
ISBLANK(Fund_Manager__c)
)</errorConditionFormula>
    <errorDisplayField>Fund_Manager__c</errorDisplayField>
    <errorMessage>Fund Manager is required for a Biography.</errorMessage>
</ValidationRule>
