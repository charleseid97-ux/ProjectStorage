<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR02_CUSIPCode</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT($User.BypassValidationRules__c),
  NOT(ISBLANK(CUSIPCode__c)),
  NOT(REGEX(CUSIPCode__c, &quot;^[0-9A-Z]{9}$&quot;))
)</errorConditionFormula>
    <errorDisplayField>CUSIPCode__c</errorDisplayField>
    <errorMessage>CUSIP Code must be exactly 9 uppercase alphanumeric characters (no spaces or special characters).</errorMessage>
</ValidationRule>
