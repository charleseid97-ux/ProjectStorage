<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR05_SEDOLCode</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT($User.BypassValidationRules__c),
  NOT(ISBLANK(SEDOLCode__c)),
  NOT(REGEX(SEDOLCode__c, &quot;^[A-Z0-9]{7}$&quot;))
)</errorConditionFormula>
    <errorDisplayField>SEDOLCode__c</errorDisplayField>
    <errorMessage>SEDOL must be exactly 7 alphanumeric characters (letters and numbers only).</errorMessage>
</ValidationRule>
