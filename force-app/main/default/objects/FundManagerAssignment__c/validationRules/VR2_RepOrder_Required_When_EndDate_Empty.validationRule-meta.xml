<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR2_RepOrder_Required_When_EndDate_Empty</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  ISBLANK(EndDate__c),
  ISBLANK(TEXT(RepOrder__c))
)</errorConditionFormula>
    <errorDisplayField>RepOrder__c</errorDisplayField>
    <errorMessage>RepOrder is required when End Date is empty.</errorMessage>
</ValidationRule>
