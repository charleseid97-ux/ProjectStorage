<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR02_EndDateControl</fullName>
    <active>true</active>
    <errorConditionFormula>AND (
				NOT($User.BypassValidationRules__c),
				EndDate__c &gt; TODAY()
)</errorConditionFormula>
    <errorDisplayField>EndDate__c</errorDisplayField>
    <errorMessage>The end date cannot be greater than today.</errorMessage>
</ValidationRule>
