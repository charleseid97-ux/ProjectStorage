<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>isCompetitor__c</fullName>
    <description>Check if contact&apos;s company is competitor</description>
    <formula>ISPICKVAL(Account.Competitor__c, &quot;Yes&quot;) || ISPICKVAL(Account.Type, &quot;Competitor&quot;)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>isCompetitor</label>
    <trackHistory>false</trackHistory>
    <type>Checkbox</type>
</CustomField>
