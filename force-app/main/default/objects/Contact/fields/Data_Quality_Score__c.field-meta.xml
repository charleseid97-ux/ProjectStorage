<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Data_Quality_Score__c</fullName>
    <description>Calculate score based on important field for contacts</description>
    <externalId>false</externalId>
    <formula>IF(ISBLANK(TEXT(Salutation)),0,10)
+IF(OR(LEN(LastName)=0,LEN(FirstName)=0),0,15)
+IF(LEN(AccountId)=0,0,10)
+IF(ISBLANK(TEXT(JobFunction__c)),0,5)
+IF(ISBLANK(TEXT(Persona__c)),0,5)
+IF(ISBLANK(TEXT(Language__c)),0,10)
+IF(LEN(Email)=0,0,15)
+IF(LEN(Phone)=0,0,10)
+IF(HasOptedOutOfEmail=TRUE,0,5)
+IF(OR(LEN(MailingCountry)=0,LEN(MailingCity)=0,LEN(MailingStreet)=0),0,10)
+IF(ISBLANK(TEXT(Source__c)),0,5)</formula>
    <label>Data Quality Score</label>
    <precision>18</precision>
    <required>false</required>
    <scale>0</scale>
    <trackHistory>false</trackHistory>
    <type>Number</type>
    <unique>false</unique>
</CustomField>
