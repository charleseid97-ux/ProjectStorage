<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Data_Quality_Description__c</fullName>
    <description>Explain which field is missing when scoring is not 100</description>
    <externalId>false</externalId>
    <formula>IF( Data_Quality_Score__c =100,&quot;OK&quot;,&quot;Missing: &quot;
&amp;IF(LEN(Email)=0, &quot;Email, &quot;,&quot;&quot;)&amp;&quot;&quot;
&amp;IF(ISBLANK(TEXT(Salutation)), &quot;Salutation, &quot;,&quot;&quot;)&amp;&quot;&quot;
&amp;IF(ISBLANK(TEXT(JobFunction__c)), &quot;Job Function__c, &quot;,&quot;&quot;)&amp;&quot;&quot;
&amp;IF(ISBLANK(TEXT(Persona__c)), &quot;Persona, &quot;,&quot;&quot;)&amp;&quot;&quot;
&amp;IF(ISBLANK(TEXT(Language__c)), &quot;Language, &quot;,&quot;&quot;)&amp;&quot;&quot;
&amp;IF(OR(LEN(MailingCountry)=0,LEN(MailingCity)=0,LEN(MailingStreet)=0), &quot;Address, &quot;,&quot;&quot;)&amp;&quot;&quot;
&amp;IF(ISBLANK(TEXT(Source__c)), &quot;Source, &quot;,&quot;&quot;)&amp;&quot;&quot;
&amp;IF(LEN(Phone)=0, &quot;Phone, &quot;,&quot;&quot;))</formula>
    <label>Data Quality Description</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
