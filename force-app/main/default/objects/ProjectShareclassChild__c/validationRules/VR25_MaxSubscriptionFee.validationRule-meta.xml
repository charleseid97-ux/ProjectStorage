<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR25_MaxSubscriptionFee</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT($User.BypassValidationRules__c),
  OR(
    MaxSubscriptionFee__c &lt; 0,
    MaxSubscriptionFee__c &gt; 0.04
  )
)</errorConditionFormula>
    <errorMessage>Max Subscription Fee must be between 0% and 4%</errorMessage>
</ValidationRule>
