<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR31_CFICode</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT($User.BypassValidationRules__c),
  NOT(ISBLANK(CFICode__c)),
  NOT(REGEX(CFICode__c, &quot;^[A-Z]{6}$&quot;))
)</errorConditionFormula>
    <errorMessage>Invalid CFI Code format. Please enter exactly 6 uppercase letters (A–Z), e.g., &apos;ESVUFR&apos;.</errorMessage>
</ValidationRule>
