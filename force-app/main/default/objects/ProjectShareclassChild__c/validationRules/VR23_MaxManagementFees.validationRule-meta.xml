<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR23_MaxManagementFees</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT($User.BypassValidationRules__c),
  OR(
    MaxManagementFees__c &lt; 0,
    MaxManagementFees__c &gt; 0.03
  )
)</errorConditionFormula>
    <errorMessage>Max Management Fees must be between 0% and 3%</errorMessage>
</ValidationRule>
