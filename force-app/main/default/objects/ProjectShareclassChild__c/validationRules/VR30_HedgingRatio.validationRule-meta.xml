<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR30_HedgingRatio</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT($User.BypassValidationRules__c),
  OR(
    HedgingRatio__c &lt; 0,
    HedgingRatio__c &gt; 1
  )
)</errorConditionFormula>
    <errorMessage>Hedging ratio must be between 0% and 100%</errorMessage>
</ValidationRule>
