<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR26_DecimalsMaxAmount</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT($User.BypassValidationRules__c),
  OR(
    DecimalsMaxAmount__c &lt; 0,
    DecimalsMaxAmount__c &gt; 3
  )
)</errorConditionFormula>
    <errorMessage>Decimals Max Amount must be between 0 and 3</errorMessage>
</ValidationRule>
