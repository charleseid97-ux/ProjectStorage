<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR24_MaxPerfFees</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT($User.BypassValidationRules__c),
  OR(
    MaxPerfFees__c &lt; 0,
    MaxPerfFees__c &gt; 0.2
  )
)</errorConditionFormula>
    <errorMessage>Max Perf Fees must be between 0% and 20%</errorMessage>
</ValidationRule>
