<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Lead_VR07_TrialStatusMandatory</fullName>
    <active>false</active>
    <description>Trial Status is mandatory if Website Role is ProSpace Temp</description>
    <errorConditionFormula>AND(NOT($User.BypassValidationRules__c),AND(ispickval(WebsiteRole__c,&quot;5&quot;),isblank(Text(TrialStatus__c))))</errorConditionFormula>
    <errorDisplayField>TrialStatus__c</errorDisplayField>
    <errorMessage>You selected ProSpace Temp. Trial Status is mandatory</errorMessage>
</ValidationRule>
