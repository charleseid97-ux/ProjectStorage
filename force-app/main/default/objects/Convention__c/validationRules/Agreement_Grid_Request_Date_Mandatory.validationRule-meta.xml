<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Agreement_Grid_Request_Date_Mandatory</fullName>
    <active>true</active>
    <description>Start Date is mandatory when requesting a new Grid</description>
    <errorConditionFormula>AND(
  NOT(ISBLANK(Grid_Request__c)),
  ISBLANK(Grid_Request_Start_Date__c),
  NOT( $User.BypassValidationRules__c )
)</errorConditionFormula>
    <errorDisplayField>Grid_Request_Start_Date__c</errorDisplayField>
    <errorMessage>You must enter a Grid Start Date when requesting a new Grid</errorMessage>
</ValidationRule>
