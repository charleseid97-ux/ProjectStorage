<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR13_MasterFundMandatory</fullName>
    <active>true</active>
    <description>Display ONLY if IsFeeder=&quot;True&quot;</description>
    <errorConditionFormula>AND(
NOT($User.BypassValidationRules__c),
$Permission.PRPProductStrategy ,
RecordType.DeveloperName = &apos;DesignAndProposal&apos;,
ISPICKVAL(IsFeeder__c, &apos;True&apos;),
ISBLANK(MasterFund__c)
				)</errorConditionFormula>
    <errorDisplayField>MasterFund__c</errorDisplayField>
    <errorMessage>If Is Feeder = True, please provide a value for Master Fund</errorMessage>
</ValidationRule>
