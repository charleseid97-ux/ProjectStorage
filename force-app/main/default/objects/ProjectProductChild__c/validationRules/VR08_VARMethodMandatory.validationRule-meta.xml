<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR08_VARMethodMandatory</fullName>
    <active>false</active>
    <description>Display &amp; Mandatory ONLY If GlobalRiskMethod = &quot;Absolute VaR&quot; OR &quot;Relative VaR&quot;</description>
    <errorConditionFormula>AND(
NOT($User.BypassValidationRules__c),
$Permission.PRPRisk,
OR(ISPICKVAL(ProjectProductParent__r.GlobalRiskMethod__c, &apos;Absolute VaR&apos;),
			ISPICKVAL(ProjectProductParent__r.GlobalRiskMethod__c, &apos;Relative VaR&apos;)),
ISBLANK(TEXT(VARMethod__c))
				)</errorConditionFormula>
    <errorDisplayField>VARMethod__c</errorDisplayField>
    <errorMessage>If GlobalRiskMethod = &quot;Absolute VaR&quot; OR &quot;Relative VaR&quot;, please provide a value for VAR Method.</errorMessage>
</ValidationRule>
