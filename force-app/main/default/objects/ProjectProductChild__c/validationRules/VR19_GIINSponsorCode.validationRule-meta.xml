<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR19_GIINSponsorCode</fullName>
    <active>true</active>
    <errorConditionFormula>AND(
  NOT($User.BypassValidationRules__c),
  NOT(ISBLANK(GIINSponsorCode__c)),
  NOT(REGEX(GIINSponsorCode__c, &quot;^[A-Z0-9]{6}\\.[0-9]{5}\\.[A-Z]{2}\\.[A-Z0-9]{3}$&quot;))
)</errorConditionFormula>
    <errorDisplayField>GIINSponsorCode__c</errorDisplayField>
    <errorMessage>The GIIN Sponsor Code format is invalid. Expected format: ABCDEF.12345.SL.XXX</errorMessage>
</ValidationRule>
