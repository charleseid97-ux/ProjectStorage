<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>VR15_MinSustainableInvestMandatory</fullName>
    <active>false</active>
    <description>Display &amp; Mandatory only if SFDRcategory = 8 ou 9;
&gt; Conflit avec Display conditionnel</description>
    <errorConditionFormula>AND(
NOT($User.BypassValidationRules__c),
$Permission.PRPESG,
Name = &apos;Proposal&apos;,
OR(ISPICKVAL(ProjectProductParent__r.SFDRcategory__c , &apos;8&apos;),
ISPICKVAL(ProjectProductParent__r.SFDRcategory__c , &apos;9&apos;)),
ISBLANK(MinSustainableInvest__c)
				)</errorConditionFormula>
    <errorDisplayField>MinSustainableInvest__c</errorDisplayField>
    <errorMessage>If SFDRcategory = 8 ou 9, please provide a value for Minimum Sustainable Investment (20180).</errorMessage>
</ValidationRule>
