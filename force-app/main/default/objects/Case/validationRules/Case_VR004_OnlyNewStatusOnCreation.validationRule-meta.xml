<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Case_VR004_OnlyNewStatusOnCreation</fullName>
    <active>true</active>
    <description>Only request with &quot;new&quot; status can be created</description>
    <errorConditionFormula>AND(NOT($User.BypassValidationRules__c),
ISNEW(),
NOT(ISPICKVAL(Status,&quot;New&quot;)))</errorConditionFormula>
    <errorDisplayField>Status</errorDisplayField>
    <errorMessage>You can only create requests with &quot;New&quot; Status</errorMessage>
</ValidationRule>
