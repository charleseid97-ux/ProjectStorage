<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Case_VR005_DueDate</fullName>
    <active>true</active>
    <description>Due Date must be in the future</description>
    <errorConditionFormula>AND(NOT($User.BypassValidationRules__c), 
ISNEW(), 
Due_date__c &lt; TODAY() )</errorConditionFormula>
    <errorDisplayField>Due_date__c</errorDisplayField>
    <errorMessage>You cannot enter a Due Date before today... nice try!</errorMessage>
</ValidationRule>
