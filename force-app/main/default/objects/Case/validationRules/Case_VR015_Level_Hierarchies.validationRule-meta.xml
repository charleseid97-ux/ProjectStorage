<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Case_VR015_Level_Hierarchies</fullName>
    <active>true</active>
    <description>AND(!$User.BypassValidationRules__c,
					  NOT(ISBLANK(Parent.ParentId ) )
