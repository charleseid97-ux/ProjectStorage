<?xml version="1.0" encoding="UTF-8"?>
<ValidationRule xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>Web_Comm_VR03_InvalidSite</fullName>
    <active>false</active>
    <errorConditionFormula>AND(!$User.BypassValidationRules__c,
				 CONTAINS($User.LastName, &apos;ProSpace&apos;), 
				ISBLANK(AlertTypeRecord__r.Site__c) ||
				NOT(CONTAINS(AlertTypeRecord__r.Site__c, Contact__r.WebsiteCountryLanguage__c)))</errorConditionFormula>
    <errorDisplayField>AlertTypeRecord__c</errorDisplayField>
    <errorMessage>Le site selectioné sur ce theme n&apos;est pas valide.</errorMessage>
</ValidationRule>
