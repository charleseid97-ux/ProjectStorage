<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>TECH_User_Website_Country__c</fullName>
    <description>Get the website country of the user whether it is a lead or contact
Used to align migration data</description>
    <externalId>false</externalId>
    <formula>IF(LEN(Lead__c) &gt; 0, TEXT(Lead__r.WebsiteCountry__c), TEXT(Contact__r.WebsiteCountry__c))</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>TECH_User_Website_Country</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
