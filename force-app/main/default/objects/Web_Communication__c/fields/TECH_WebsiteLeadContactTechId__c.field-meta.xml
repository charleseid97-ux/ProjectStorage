<?xml version="1.0" encoding="UTF-8"?>
<CustomField xmlns="http://soap.sforce.com/2006/04/metadata">
    <fullName>TECH_WebsiteLeadContactTechId__c</fullName>
    <description>Retrieves the website technical Id for lead or contact. This field is used in the after delete trigger to send those information to website.</description>
    <externalId>false</externalId>
    <formula>IF(ISBLANK(Contact__c), Lead__r.TECH_WebSiteID__c,Contact__r.TECH_WebSiteID__c)</formula>
    <formulaTreatBlanksAs>BlankAsZero</formulaTreatBlanksAs>
    <label>TECH_WebsiteLeadContactTechId</label>
    <required>false</required>
    <trackHistory>false</trackHistory>
    <trackTrending>false</trackTrending>
    <type>Text</type>
    <unique>false</unique>
</CustomField>
