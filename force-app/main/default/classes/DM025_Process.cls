	  public static List<Process_Id__c> getListByIndex(Set<String> processId){
        
        String methodName = 'getListByIndex';    
        ObjectUtil.debugLogBegin(CLASS_NAME, methodName, '[processId] :' + processId);
        
        String soqlQuery = 'SELECT ' + ALL_FIELDS + ' FROM Process_Id__c WHERE Index__c IN: processId';    
        List<Process_Id__c> listreturn = new List<Process_Id__c>((List<Process_Id__c>)Database.query(soqlQuery));
        
        ObjectUtil.debugLogEnd(CLASS_NAME, methodName, '[RESULTS] :' + listreturn);
        return listreturn; 
    }
    
