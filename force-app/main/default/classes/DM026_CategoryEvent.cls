	  public static Category_Event__c get1ListById(Set<Id> categoryEventID){
        
        String methodName = 'getListById';    
        ObjectUtil.debugLogBegin(CLASS_NAME, methodName, '[categoryEventID] :' + categoryEventID);
        
        String soqlQuery = 'SELECT ' + ALL_FIELDS + ' FROM Category_Event__c WHERE Id IN: categoryEventID LIMIT 1';    
        List<Category_Event__c> listreturn = new List<Category_Event__c>((List<Category_Event__c>)Database.query(soqlQuery));
        
        Category_Event__c returnOnlyOne = listreturn.get(0);
        
        ObjectUtil.debugLogEnd(CLASS_NAME, methodName, '[RESULTS] :' + listreturn);
        return returnOnlyOne; 
    }
    
